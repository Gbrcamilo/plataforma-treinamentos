# Banco de dados - Neon PostgreSQL (gratuito)
# Crie sua conta em https://neon.tech e cole a connection string abaixo
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/plataforma_treinamentos?sslmode=require"

# JWT Secret - gere uma string aleatória longa
JWT_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"

# Ambiente
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
